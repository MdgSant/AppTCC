<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.ListagemDuvidasAlunoView"
             Title="Dúvidas"
             BackgroundColor="#1a1a2e">
	<Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="16">
		<VerticalStackLayout Grid.Row="0" Spacing="4">
			<Label Text="? Minhas Dúvidas"
                   FontSize="24" FontAttributes="Bold" TextColor="#c084fc" />
			<BoxView HeightRequest="1" BackgroundColor="#3d3b6e" Margin="0,8,0,0" />
		</VerticalStackLayout>
		<CollectionView Grid.Row="1" ItemsSource="{Binding Duvidas}">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Frame BackgroundColor="#2d2b55" CornerRadius="14"
                           Padding="16" BorderColor="#3d3b6e" Margin="0,0,0,12">
						<Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
							<Grid Grid.Row="0" ColumnDefinitions="*,Auto">
								<Label Grid.Column="0"
                                       Text="{Binding Titulo}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#c084fc" />
								<Frame Grid.Column="1" CornerRadius="8"
                                       Padding="8,4" BorderColor="Transparent"
                                       BackgroundColor="#1a3a1a">
									<Frame.Triggers>
										<DataTrigger TargetType="Frame"
                                                     Binding="{Binding StatusDuvida}"
                                                     Value="Aberta">
											<Setter Property="BackgroundColor" Value="#3a2a0a" />
										</DataTrigger>
										<DataTrigger TargetType="Frame"
                                                     Binding="{Binding StatusDuvida}"
                                                     Value="Respondida">
											<Setter Property="BackgroundColor" Value="#1a3a1a" />
										</DataTrigger>
									</Frame.Triggers>
									<Label Text="{Binding StatusDuvida}" FontSize="12">
										<Label.Triggers>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding StatusDuvida}"
                                                         Value="Aberta">
												<Setter Property="TextColor" Value="#f59e0b" />
											</DataTrigger>
											<DataTrigger TargetType="Label"
                                                         Binding="{Binding StatusDuvida}"
                                                         Value="Respondida">
												<Setter Property="TextColor" Value="#4ade80" />
											</DataTrigger>
										</Label.Triggers>
									</Label>
								</Frame>
							</Grid>
							<Label Grid.Row="1"
                                   Text="{Binding Disciplina.Nome}"
                                   FontSize="12" TextColor="#a0a0c0" />
							<Label Grid.Row="2"
                                   Text="{Binding Descricao}"
                                   FontSize="13" TextColor="#a0a0c0"
                                   LineBreakMode="TailTruncation" MaxLines="2" />
							<Label Grid.Row="3"
                                   Text="{Binding Momento, StringFormat='📅 {0:dd/MM/yyyy}'}"
                                   FontSize="12" TextColor="#a0a0c0"
                                   HorizontalOptions="End" />
						</Grid>
					</Frame>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>
		<Button Grid.Row="2"
                Text="+ Nova Dúvida"
                BackgroundColor="#7c3aed"
                TextColor="White"
                CornerRadius="12"
                FontSize="15"
                FontAttributes="Bold"
                HeightRequest="52"
                Clicked="OnNovaDuvidaClicked" />
	</Grid>
</ContentPage>