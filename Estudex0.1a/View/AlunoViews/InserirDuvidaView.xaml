<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.InserirDuvidaView"
             Title="Nova Dúvida"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="InputFrame">
            <Setter Property="BackgroundColor" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasShadow" Value="False"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <!-- Círculos Decorativos -->
        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Header -->
                <Frame Style="{StaticResource CardStyle}">
                    <HorizontalStackLayout Spacing="15">
                        <Grid WidthRequest="55" HeightRequest="55">
                            <Ellipse Fill="#BB86FC20"/>
                            <Label Text="?" FontSize="26" TextColor="#BB86FC" 
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                        <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                            <Label Text="CRIAR NOVA DÚVIDA" 
                                   FontSize="18" FontAttributes="Bold" 
                                   TextColor="#a21fa2"/>
                            <Label Text="Descreva sua dúvida com detalhes" 
                                   FontSize="12" TextColor="#9E9E9E"/>
                            <Label Text="✦ Resposta garantida em até 24h ✦" 
                                   FontSize="10" TextColor="#BB86FC"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Card Formulário -->
                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="20">

                        <!-- Título -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🏷 TÍTULO DA DÚVIDA" 
                                   FontSize="11" FontAttributes="Bold" 
                                   TextColor="#BB86FC"/>
                            <Frame Style="{StaticResource InputFrame}" HeightRequest="50">
                                <Entry Text="{Binding Titulo}"
                                       Placeholder="Ex: Dúvida sobre Bhaskara"
                                       PlaceholderColor="#6B6B6B"
                                       TextColor="#E0E0E0"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Disciplina -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="📚 DISCIPLINA" 
                                   FontSize="11" FontAttributes="Bold" 
                                   TextColor="#BB86FC"/>
                            <Frame Style="{StaticResource InputFrame}" HeightRequest="50">
                                <Picker Title="Selecione uma disciplina"
                                        TitleColor="#6B6B6B"
                                        TextColor="#E0E0E0"
                                        BackgroundColor="Transparent"
                                        ItemsSource="{Binding ListaDisciplinas}"
                                        ItemDisplayBinding="{Binding Nome}"
                                        SelectedItem="{Binding DisciplinaSelecionada}"
                                        VerticalOptions="Center"
                                        Margin="10,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Descrição -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="📖 DESCRIÇÃO DETALHADA" 
                                   FontSize="11" FontAttributes="Bold" 
                                   TextColor="#BB86FC"/>
                            <Frame Style="{StaticResource InputFrame}" Padding="12">
                                <Editor Text="{Binding Descricao}"
                                        Placeholder="Descreva sua dúvida em detalhes...&#xa;&#xa;• O que você já tentou?&#xa;• Onde está sua dificuldade?&#xa;• Exemplos ou códigos relacionados"
                                        PlaceholderColor="#6B6B6B"
                                        TextColor="#E0E0E0"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        HeightRequest="160"/>
                            </Frame>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <!-- Botão Enviar -->
                <Button Text="✈ ENVIAR DÚVIDA"
                        Background="{StaticResource PrimaryGradient}"
                        TextColor="#121212"
                        CornerRadius="25"
                        FontSize="14"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Margin="0,10,0,0"
                        Command="{Binding SalvarDuvidaCommand}"/>

                <!-- Loading -->
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>