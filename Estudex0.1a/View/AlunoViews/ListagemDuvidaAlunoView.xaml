<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.ListagemDuvidasAlunoView"
             Title="Dúvidas"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="DuvidaCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="StatCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <!-- Círculos Decorativos -->
        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Header -->
                <HorizontalStackLayout>
                    <Label Text="?" FontSize="28" TextColor="#BB86FC"/>
                    <Label Text="MINHAS DÚVIDAS" 
                           FontSize="20" FontAttributes="Bold" 
                           TextColor="#a21fa2"/>
                </HorizontalStackLayout>

                <!-- Stats Cards -->
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">

                    <Frame Style="{StaticResource StatCard}" WidthRequest="100">
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="⏳" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="PENDENTES" FontSize="9" TextColor="#9E9E9E" FontAttributes="Bold"/>
                            <Label Text="{Binding TotalPendentes}" FontSize="26" FontAttributes="Bold" TextColor="#FFC107" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Style="{StaticResource StatCard}" WidthRequest="100">
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="✓" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="RESPONDIDAS" FontSize="9" TextColor="#9E9E9E" FontAttributes="Bold"/>
                            <Label Text="{Binding TotalRespondidas}" FontSize="26" FontAttributes="Bold" TextColor="#00E676" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Style="{StaticResource StatCard}" WidthRequest="100">
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="TOTAL" FontSize="9" TextColor="#9E9E9E" FontAttributes="Bold"/>
                            <Label Text="{Binding TotalDuvidas}" FontSize="26" FontAttributes="Bold" TextColor="#BB86FC" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </HorizontalStackLayout>

                <!-- Barra de Busca -->
                <Frame Style="{StaticResource CardStyle}" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🔍" FontSize="14" TextColor="#BB86FC" VerticalOptions="Center"/>
                        <Entry x:Name="EntryBusca"
                               Placeholder="Buscar por título ou disciplina..."
                               PlaceholderColor="#6B6B6B"
                               TextColor="#E0E0E0"
                               BackgroundColor="Transparent"
                               HorizontalOptions="FillAndExpand"
                               FontSize="13"/>
                        <Button Text="BUSCAR"
                                BackgroundColor="#BB86FC"
                                TextColor="#121212"
                                CornerRadius="10"
                                FontSize="11"
                                FontAttributes="Bold"
                                WidthRequest="70"
                                HeightRequest="35"
                                Clicked="OnBuscarClicked"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Título da Lista -->
                <Label Text="📋 MINHAS DÚVIDAS" 
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#BB86FC" Margin="0,5,0,5"/>

                <!-- Lista de Dúvidas -->
                <CollectionView ItemsSource="{Binding Duvidas}"
                                SelectionMode="Single"
                                SelectionChanged="OnDuvidaSelecionada">
                    <CollectionView.EmptyView>
                        <Frame Style="{StaticResource CardStyle}" Padding="40">
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="💬" FontSize="40" HorizontalOptions="Center"/>
                                <Label Text="Nenhuma dúvida cadastrada." 
                                       FontSize="13" TextColor="#9E9E9E" HorizontalOptions="Center"/>
                                <Label Text="Clique em + NOVA DÚVIDA para começar" 
                                       FontSize="11" TextColor="#BB86FC" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource DuvidaCard}">
                                <VerticalStackLayout Spacing="12">

                                    <!-- Header: Título + Status -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding Titulo}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#E0E0E0"/>

                                        <!-- Status Badge -->
                                        <Frame Grid.Column="1" CornerRadius="10" Padding="10,4" HasShadow="False">
                                            <Frame.Triggers>
                                                <DataTrigger TargetType="Frame" Binding="{Binding StatusDuvida}" Value="aberta">
                                                    <Setter Property="BackgroundColor" Value="#FFC10720"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" Binding="{Binding StatusDuvida}" Value="pendente">
                                                    <Setter Property="BackgroundColor" Value="#FFC10720"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" Binding="{Binding StatusDuvida}" Value="respondida">
                                                    <Setter Property="BackgroundColor" Value="#00E67620"/>
                                                </DataTrigger>
                                            </Frame.Triggers>

                                            <Label FontSize="10" FontAttributes="Bold">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding StatusDuvida}" Value="aberta">
                                                        <Setter Property="Text" Value="⏳ PENDENTE"/>
                                                        <Setter Property="TextColor" Value="#FFC107"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding StatusDuvida}" Value="pendente">
                                                        <Setter Property="Text" Value="⏳ PENDENTE"/>
                                                        <Setter Property="TextColor" Value="#FFC107"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding StatusDuvida}" Value="respondida">
                                                        <Setter Property="Text" Value="✓ RESPONDIDA"/>
                                                        <Setter Property="TextColor" Value="#00E676"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Frame>
                                    </Grid>

                                    <!-- Disciplina -->
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="📚" FontSize="11"/>
                                        <Label Text="{Binding Disciplina.Nome}"
                                               FontSize="12" TextColor="#a21fa2"/>
                                    </HorizontalStackLayout>

                                    <!-- Descrição Preview -->
                                    <Label Text="{Binding Descricao}"
                                           FontSize="12" TextColor="#9E9E9E"
                                           MaxLines="2" 
                                           LineBreakMode="TailTruncation"/>

                                    <!-- Footer: Data -->
                                    <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                        <Label Text="📅" FontSize="10" TextColor="#6B6B6B"/>
                                        <Label Text="{Binding Momento, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                               FontSize="11" TextColor="#6B6B6B"/>
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Botão Nova Dúvida -->
                <Button Text="+ NOVA DÚVIDA"
                        Background="{StaticResource PrimaryGradient}"
                        TextColor="#121212"
                        CornerRadius="25"
                        FontSize="13"
                        FontAttributes="Bold"
                        HeightRequest="45"
                        Margin="0,10,0,20"
                        Clicked="OnNovaDuvidaClicked"/>

                <!-- Loading -->
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>