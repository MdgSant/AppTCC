<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.MinhasRespostasView"
             Title="Minhas Atividades"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SuccessGradient" EndPoint="1,0">
            <GradientStop Color="#00E676" Offset="0" />
            <GradientStop Color="#4CAF50" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="StatCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="RespostaCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <!-- Círculos Decorativos -->
        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Header -->
                <HorizontalStackLayout>
                    <Label Text="📋" FontSize="26" TextColor="#BB86FC"/>
                    <Label Text="MINHAS ATIVIDADES" 
                           FontSize="20" FontAttributes="Bold" 
                           TextColor="#a21fa2"/>
                </HorizontalStackLayout>

                <!-- Cards de Métricas -->
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">

                    <!-- Respondidas -->
                    <Frame Style="{StaticResource StatCard}" WidthRequest="140">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="✅" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="RESPONDIDAS" FontSize="10" TextColor="#9E9E9E" FontAttributes="Bold"/>
                            <Label Text="{Binding TotalRespondidas}" 
                                   FontSize="28" FontAttributes="Bold" 
                                   TextColor="#BB86FC" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Média Geral -->
                    <Frame Style="{StaticResource StatCard}" WidthRequest="140">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="MÉDIA GERAL" FontSize="10" TextColor="#9E9E9E" FontAttributes="Bold"/>
                            <Label Text="{Binding MediaPontuacao, StringFormat='{0:F1}'}" 
                                   FontSize="28" FontAttributes="Bold" 
                                   TextColor="#00E676" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </HorizontalStackLayout>

                <!-- Título da Lista -->
                <Label Text="📝 ATIVIDADES REALIZADAS" 
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#BB86FC" Margin="0,5,0,5"/>

                <!-- Lista de Respostas -->
                <CollectionView ItemsSource="{Binding Respostas}">
                    <CollectionView.EmptyView>
                        <Frame Style="{StaticResource CardStyle}" Padding="50">
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="📭" FontSize="40" HorizontalOptions="Center"/>
                                <Label Text="Você ainda não respondeu nenhuma atividade." 
                                       FontSize="13" TextColor="#9E9E9E" HorizontalOptions="Center"/>
                                <Label Text="Acesse a aba de Atividades para começar" 
                                       FontSize="11" TextColor="#BB86FC" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource RespostaCard}">
                                <VerticalStackLayout Spacing="12">

                                    <!-- Título + Pontuação -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                                            <Label Text="{Binding Atividade.Titulo}"
                                                   FontSize="15" FontAttributes="Bold"
                                                   TextColor="#E0E0E0"/>
                                            <Label Text="{Binding Atividade.NivelDificuldade.Nome}"
                                                   FontSize="11" TextColor="#a21fa2"/>
                                        </VerticalStackLayout>

                                        <!-- Badge de Pontuação -->
                                        <Frame Grid.Column="1" CornerRadius="10" Padding="10,4" HasShadow="False"
                                               BackgroundColor="#00E67620">
                                            <Label Text="{Binding Pontuacao, StringFormat='⭐ {0:F1} pts'}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="#00E676"/>
                                        </Frame>
                                    </Grid>

                                    <!-- Separador -->
                                    <BoxView HeightRequest="1" BackgroundColor="#2A2A2A"/>

                                    <!-- Footer: Pontuação Máxima + Data -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                            <Label Text="🏆" FontSize="11"/>
                                            <Label Text="Máximo:" FontSize="11" TextColor="#9E9E9E"/>
                                            <Label Text="{Binding Atividade.PontuacaoMaxima, StringFormat='{0} pts'}"
                                                   FontSize="12" FontAttributes="Bold" TextColor="#BB86FC"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="📅" FontSize="10" TextColor="#6B6B6B"/>
                                            <Label Text="{Binding MomentoFim, StringFormat='{0:dd/MM/yyyy}'}"
                                                   FontSize="11" TextColor="#6B6B6B"/>
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- Botão Ver Detalhes -->
                                    <Button Text="👁️ VER DETALHES"
                                            BackgroundColor="#2A2A2A"
                                            TextColor="#BB86FC"
                                            CornerRadius="10"
                                            FontSize="11"
                                            FontAttributes="Bold"
                                            HeightRequest="35"
                                            HorizontalOptions="End"
                                            WidthRequest="120"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, 
                                                              Path=BindingContext.VerDetalhesCommand}"
                                            CommandParameter="{Binding .}"/>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Loading -->
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>