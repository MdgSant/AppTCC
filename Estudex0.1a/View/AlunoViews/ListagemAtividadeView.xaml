<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.ListagemAtividadeAlunoView"
             Title="Atividades"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="AtividadeCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="StatCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <!-- Círculos Decorativos -->
        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Header -->
                <HorizontalStackLayout>
                    <Label Text="📋" FontSize="26" TextColor="#BB86FC"/>
                    <Label Text="ATIVIDADES DISPONÍVEIS" 
                           FontSize="20" FontAttributes="Bold" 
                           TextColor="#a21fa2"/>
                </HorizontalStackLayout>

                <!-- Card Total de Atividades -->
                <Frame Style="{StaticResource StatCard}">
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Grid WidthRequest="50" HeightRequest="50">
                            <Ellipse Fill="#BB86FC20"/>
                            <Label Text="📋" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="TOTAL DE ATIVIDADES" FontSize="11" TextColor="#9E9E9E" FontAttributes="Bold"/>
                            <Label Text="{Binding TotalAtividades}" FontSize="28" FontAttributes="Bold" TextColor="#BB86FC"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Barra de Filtros -->
                <HorizontalStackLayout Spacing="12">
                    <Frame Style="{StaticResource CardStyle}" Padding="10" HorizontalOptions="FillAndExpand">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🔍" FontSize="14" TextColor="#BB86FC" VerticalOptions="Center"/>
                            <Entry Placeholder="Buscar atividade..."
                                   PlaceholderColor="#6B6B6B"
                                   TextColor="#E0E0E0"
                                   BackgroundColor="Transparent"
                                   HorizontalOptions="FillAndExpand"
                                   FontSize="13"
                                   Text="{Binding Busca}"/>
                        </HorizontalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="#2A2A2A" CornerRadius="12" Padding="10" WidthRequest="120">
                        <Picker Title="Filtro"
                                TitleColor="#6B6B6B"
                                TextColor="#E0E0E0"
                                BackgroundColor="Transparent"
                                SelectedItem="{Binding FiltroSelecionado}">
                            <Picker.Items>
                                <x:String>Todas</x:String>
                                <x:String>Não Respondidas</x:String>
                                <x:String>Respondidas</x:String>
                            </Picker.Items>
                        </Picker>
                    </Frame>
                </HorizontalStackLayout>

                <!-- Título da Lista -->
                <Label Text="📝 MINHAS ATIVIDADES" 
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#BB86FC" Margin="0,5,0,5"/>

                <!-- Lista de Atividades -->
                <CollectionView ItemsSource="{Binding Atividades}"
                                SelectionMode="Single"
                                SelectionChanged="OnAtividadeSelecionada">
                    <CollectionView.EmptyView>
                        <Frame Style="{StaticResource CardStyle}" Padding="50">
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="📭" FontSize="40" HorizontalOptions="Center"/>
                                <Label Text="Nenhuma atividade disponível no momento." 
                                       FontSize="13" TextColor="#9E9E9E" HorizontalOptions="Center"/>
                                <Label Text="Volte mais tarde para novas atividades" 
                                       FontSize="11" TextColor="#BB86FC" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource AtividadeCard}">
                                <VerticalStackLayout Spacing="12">

                                    <!-- Título + Badges -->
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0" 
                                               Text="{Binding Atividade.Titulo}"
                                               FontSize="15" FontAttributes="Bold" 
                                               TextColor="#E0E0E0"/>

                                        <!-- Badge "Feita" -->
                                        <Frame Grid.Column="1" CornerRadius="10" Padding="8,4" HasShadow="False"
                                               IsVisible="{Binding JaRespondeu}"
                                               BackgroundColor="#00E67620">
                                            <Label Text="✓ FEITA" FontSize="10" FontAttributes="Bold" TextColor="#00E676"/>
                                        </Frame>

                                        <!-- Badge Dificuldade -->
                                        <Frame Grid.Column="2" CornerRadius="10" Padding="8,4" HasShadow="False">
                                            <Frame.Triggers>
                                                <DataTrigger TargetType="Frame" Binding="{Binding Atividade.NivelDificuldade.Nome}" Value="Fácil">
                                                    <Setter Property="BackgroundColor" Value="#00E67620"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" Binding="{Binding Atividade.NivelDificuldade.Nome}" Value="Médio">
                                                    <Setter Property="BackgroundColor" Value="#F59E0B20"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" Binding="{Binding Atividade.NivelDificuldade.Nome}" Value="Difícil">
                                                    <Setter Property="BackgroundColor" Value="#F8717120"/>
                                                </DataTrigger>
                                            </Frame.Triggers>

                                            <Label FontSize="10" FontAttributes="Bold">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Atividade.NivelDificuldade.Nome}" Value="Fácil">
                                                        <Setter Property="Text" Value="⭐ FÁCIL"/>
                                                        <Setter Property="TextColor" Value="#00E676"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Atividade.NivelDificuldade.Nome}" Value="Médio">
                                                        <Setter Property="Text" Value="⚡ MÉDIO"/>
                                                        <Setter Property="TextColor" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Atividade.NivelDificuldade.Nome}" Value="Difícil">
                                                        <Setter Property="Text" Value="🔥 DIFÍCIL"/>
                                                        <Setter Property="TextColor" Value="#F87171"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Frame>
                                    </Grid>

                                    <!-- Separador -->
                                    <BoxView HeightRequest="1" BackgroundColor="#2A2A2A"/>

                                    <!-- Footer: Pontuação + Data -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                            <Label Text="🏆" FontSize="11"/>
                                            <Label Text="{Binding Atividade.PontuacaoMaxima, StringFormat='{0} pontos'}"
                                                   FontSize="12" TextColor="#B0B0B0"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="📅" FontSize="10" TextColor="#6B6B6B"/>
                                            <Label Text="{Binding Atividade.DataCriacao, StringFormat='{0:dd/MM/yyyy}'}"
                                                   FontSize="11" TextColor="#6B6B6B"/>
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- Botão Iniciar -->
                                    <Button Text="{Binding JaRespondeu, Converter={StaticResource RespondeuToBotaoTexto}}"
                                            Background="{StaticResource PrimaryGradient}"
                                            TextColor="#121212"
                                            CornerRadius="10"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            HeightRequest="38"
                                            Margin="0,5,0,0"/>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <!-- Footer com Carregar Mais -->
                    <CollectionView.Footer>
                        <VerticalStackLayout Padding="0,10,0,20" Spacing="10">

                            <Button Text="CARREGAR MAIS"
                                    BackgroundColor="#2A2A2A"
                                    TextColor="#BB86FC"
                                    CornerRadius="12"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    HeightRequest="44"
                                    IsVisible="{Binding TemMaisPaginas}"
                                    Command="{Binding CarregarMaisCommand}"/>

                            <ActivityIndicator Color="#BB86FC"
                                               IsRunning="{Binding CarregandoMais}"
                                               IsVisible="{Binding CarregandoMais}"
                                               HeightRequest="40"/>

                        </VerticalStackLayout>
                    </CollectionView.Footer>
                </CollectionView>

                <!-- Loading -->
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>