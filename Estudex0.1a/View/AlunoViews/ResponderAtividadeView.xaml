<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.ResultadoAtividadeView"
             Title="Resultado"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="PerguntaCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label Text="{Binding Resultado.TituloAtividade}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#a21fa2" HorizontalOptions="Center" />
                        <Label Text="{Binding Resultado.TotalAcertos, StringFormat='{0}'}"
                               FontSize="56" FontAttributes="Bold"
                               TextColor="#00E676" HorizontalOptions="Center" />
                        <Label FontSize="14" TextColor="#9E9E9E" HorizontalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="de " TextColor="#9E9E9E" />
                                    <Span Text="{Binding Resultado.TotalPerguntas}"
                                          TextColor="#E0E0E0" FontAttributes="Bold" />
                                    <Span Text=" acertos" TextColor="#9E9E9E" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <BoxView HeightRequest="1" BackgroundColor="#2A2A2A" Margin="20,0,20,0"/>
                        <Label FontSize="14" HorizontalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="🏆 Pontuação: " TextColor="#9E9E9E" />
                                    <Span Text="{Binding Resultado.Pontuacao, StringFormat='{0:F1}'}"
                                          TextColor="#00E676" FontAttributes="Bold" />
                                    <Span Text=" / " TextColor="#9E9E9E" />
                                    <Span Text="{Binding Resultado.PontuacaoMaxima}"
                                          TextColor="#E0E0E0" FontAttributes="Bold" />
                                    <Span Text=" pts" TextColor="#9E9E9E" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

                <Label Text="📝 REVISÃO DAS QUESTÕES" 
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#BB86FC" Margin="0,5,0,5"/>

                <CollectionView ItemsSource="{Binding Resultado.Perguntas}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource PerguntaCard}">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Acertou}" Value="True">
                                        <Setter Property="BorderColor" Value="#00E676"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Acertou}" Value="False">
                                        <Setter Property="BorderColor" Value="#F87171"/>
                                    </DataTrigger>
                                </Frame.Triggers>

                                <VerticalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="10">
                                        <Label FontSize="18">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Acertou}" Value="True">
                                                    <Setter Property="Text" Value="✅" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Acertou}" Value="False">
                                                    <Setter Property="Text" Value="❌" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Text="{Binding Enunciado}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="#E0E0E0"
                                               VerticalOptions="Center"
                                               LineBreakMode="WordWrap"/>
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" BackgroundColor="#2A2A2A"/>

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="📌 SUA RESPOSTA" FontSize="10" FontAttributes="Bold" TextColor="#9E9E9E" />
                                        <Frame Padding="12,8" CornerRadius="10" HasShadow="False"
                                               BackgroundColor="#252525">
                                            <Frame.Triggers>
                                                <DataTrigger TargetType="Frame" Binding="{Binding Acertou}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#00E67610"/>
                                                    <Setter Property="BorderColor" Value="#00E676"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" Binding="{Binding Acertou}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="#F8717110"/>
                                                    <Setter Property="BorderColor" Value="#F87171"/>
                                                </DataTrigger>
                                            </Frame.Triggers>
                                            <Label Text="{Binding OpcaoEscolhida}" FontSize="13">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Acertou}" Value="True">
                                                        <Setter Property="TextColor" Value="#00E676" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Acertou}" Value="False">
                                                        <Setter Property="TextColor" Value="#F87171" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Frame>
                                    </VerticalStackLayout>

                                    <!-- Resposta Correta - usando DataTrigger em vez de Converter -->
                                    <VerticalStackLayout Spacing="4">
                                        <VerticalStackLayout.Triggers>
                                            <DataTrigger TargetType="VerticalStackLayout"
                                                         Binding="{Binding Acertou}"
                                                         Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="VerticalStackLayout"
                                                         Binding="{Binding Acertou}"
                                                         Value="False">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </VerticalStackLayout.Triggers>

                                        <Label Text="✅ RESPOSTA CORRETA" FontSize="10" FontAttributes="Bold" TextColor="#9E9E9E" />
                                        <Frame Padding="12,8" CornerRadius="10" 
                                               BackgroundColor="#00E67610"
                                               BorderColor="#00E676"
                                               HasShadow="False">
                                            <Label Text="{Binding OpcaoCorreta}"
                                                   FontSize="13" TextColor="#00E676" />
                                        </Frame>
                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="← VOLTAR PARA ATIVIDADES"
                        Background="{StaticResource PrimaryGradient}"
                        TextColor="#121212"
                        CornerRadius="12"
                        FontSize="13"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        Margin="0,10,0,20"
                        Clicked="OnVoltarClicked" />

                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>