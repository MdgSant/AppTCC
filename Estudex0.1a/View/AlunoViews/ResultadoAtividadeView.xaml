<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.AlunoViews.ResultadoAtividadeView"
             Title="Resultado"
             BackgroundColor="#1a1a2e">
    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20">

            <!-- Card Resultado Geral -->
            <Frame BackgroundColor="#2d2b55" CornerRadius="16" Padding="20"
                   Margin="0,0,0,16" BorderColor="#7c3aed">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                    <Label Text="{Binding Resultado.TituloAtividade}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="#c084fc" HorizontalOptions="Center" />

                    <Label Text="{Binding Resultado.TotalAcertos, StringFormat='{0}'}"
                           FontSize="52" FontAttributes="Bold"
                           TextColor="#4ade80" HorizontalOptions="Center" />

                    <Label FontSize="16" TextColor="#a0a0c0" HorizontalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="de " TextColor="#a0a0c0" />
                                <Span Text="{Binding Resultado.TotalPerguntas}"
                                      TextColor="#e0e0ff" FontAttributes="Bold" />
                                <Span Text=" acertos" TextColor="#a0a0c0" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <BoxView HeightRequest="0.5" BackgroundColor="#3d3b6e" />

                    <Label FontSize="15" HorizontalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Pontuação: " TextColor="#a0a0c0" />
                                <Span Text="{Binding Resultado.Pontuacao, StringFormat='{0:F1}'}"
                                      TextColor="#4ade80" FontAttributes="Bold" />
                                <Span Text=" / " TextColor="#a0a0c0" />
                                <Span Text="{Binding Resultado.PontuacaoMaxima}"
                                      TextColor="#e0e0ff" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                </VerticalStackLayout>
            </Frame>

            <!-- Lista de Perguntas com Resultado -->
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Resultado.Perguntas}"
                                 Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="14" Padding="16"
                               BorderColor="#3d3b6e" BackgroundColor="#2d2b55">

                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding Acertou}" Value="True">
                                    <Setter Property="BorderColor" Value="#4ade80" />
                                </DataTrigger>
                                <DataTrigger TargetType="Frame"
                                             Binding="{Binding Acertou}" Value="False">
                                    <Setter Property="BorderColor" Value="#f87171" />
                                </DataTrigger>
                            </Frame.Triggers>

                            <VerticalStackLayout Spacing="10">

                                <!-- Ícone + Enunciado -->
                                <HorizontalStackLayout Spacing="10">
                                    <Label FontSize="18">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding Acertou}" Value="True">
                                                <Setter Property="Text" Value="✅" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding Acertou}" Value="False">
                                                <Setter Property="Text" Value="❌" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Label Text="{Binding Enunciado}"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="#e0e0ff"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <BoxView HeightRequest="0.5" BackgroundColor="#3d3b6e" />

                                <!-- Resposta do Aluno -->
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Sua resposta:" FontSize="12" TextColor="#a0a0c0" />
                                    <Frame Padding="10,6" CornerRadius="8"
                                           BorderColor="Transparent" BackgroundColor="#3a0a0a">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame"
                                                         Binding="{Binding Acertou}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#0a2a0a" />
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Label Text="{Binding OpcaoEscolhida}"
                                               FontSize="13">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding Acertou}" Value="True">
                                                    <Setter Property="TextColor" Value="#4ade80" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding Acertou}" Value="False">
                                                    <Setter Property="TextColor" Value="#f87171" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Frame>
                                </VerticalStackLayout>

                                <!-- Resposta Correta (só mostra se errou) -->
                                <VerticalStackLayout Spacing="4">
                                    <VerticalStackLayout.Triggers>
                                        <DataTrigger TargetType="VerticalStackLayout"
                                                     Binding="{Binding Acertou}" Value="True">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </VerticalStackLayout.Triggers>
                                    <Label Text="Resposta correta:" FontSize="12" TextColor="#a0a0c0" />
                                    <Frame Padding="10,6" CornerRadius="8"
                                           BorderColor="Transparent" BackgroundColor="#0a2a0a">
                                        <Label Text="{Binding OpcaoCorreta}"
                                               FontSize="13" TextColor="#4ade80" />
                                    </Frame>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Botão Voltar -->
            <Button Text="← Voltar para Atividades"
                    BackgroundColor="#7c3aed"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Margin="0,16,0,0"
                    Clicked="OnVoltarClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>