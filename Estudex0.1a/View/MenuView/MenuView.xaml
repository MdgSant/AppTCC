<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.MenuView"
             Title="Menu"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Button" x:Key="MenuButton">
            <Setter Property="BackgroundColor" Value="#2A2A2A"/>
            <Setter Property="TextColor" Value="#E0E0E0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="50"/>
            <Setter Property="HorizontalOptions" Value="Fill"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <!-- Fundo Escuro -->
        <Grid BackgroundColor="#121212"/>

        <!-- Círculos Decorativos -->
        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Logo -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,20,0,10">
                    <Label Text="📚" FontSize="36" TextColor="#BB86FC"/>
                    <Label Text="ESTUDEX" 
                           FontSize="28" FontAttributes="Bold" 
                           TextColor="#a21fa2"/>
                </HorizontalStackLayout>

                <!-- Card do Usuário -->
                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">

                        <!-- Avatar -->
                        <Grid WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                            <Ellipse Fill="#BB86FC20"/>
                            <Label Text="👤" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Nome do Usuário -->
                        <Label x:Name="LabelNome"
                               Text="Carregando..."
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#E0E0E0" 
                               HorizontalOptions="Center"/>

                        <!-- Perfil (Aluno/Professor) -->
                        <Label x:Name="LabelPerfil"
                               Text=""
                               FontSize="13"
                               TextColor="#BB86FC" 
                               HorizontalOptions="Center"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Menu Professor -->
                <VerticalStackLayout x:Name="MenuProfessor" Spacing="12">
                    <Label Text="📋 MENU PROFESSOR" 
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#9E9E9E" Margin="5,5,0,5"/>

                    <Button Style="{StaticResource MenuButton}" 
                            Clicked="OnAtividadesClicked">
                        <Button.Text>📋 Atividades</Button.Text>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" 
                            Clicked="OnDuvidasClicked">
                        <Button.Text>❓ Dúvidas dos Alunos</Button.Text>
                    </Button>
                </VerticalStackLayout>

                <!-- Menu Aluno -->
                <VerticalStackLayout x:Name="MenuAluno" Spacing="12">
                    <Label Text="📖 MENU ALUNO" 
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#9E9E9E" Margin="5,5,0,5"/>

                    <Button Style="{StaticResource MenuButton}" 
                            Clicked="OnAtividadesAlunoClicked">
                        <Button.Text>📋 Minhas Atividades</Button.Text>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" 
                            Clicked="OnDuvidasAlunoClicked">
                        <Button.Text>❓ Minhas Dúvidas</Button.Text>
                    </Button>

                    <Button Style="{StaticResource MenuButton}" 
                            Clicked="OnDuvidasGeraisClicked">
                        <Button.Text>🌐 Dúvidas Gerais</Button.Text>
                    </Button>
                </VerticalStackLayout>

                <!-- Botão Sair -->
                <Button Style="{StaticResource MenuButton}"
                        BackgroundColor="#F8717120"
                        TextColor="#F87171"
                        Margin="0,20,0,10"
                        Clicked="OnLogoutClicked">
                    <Button.Text>🚪 SAIR</Button.Text>
                </Button>

                <!-- Versão -->
                <Label Text="v1.0" 
                       FontSize="10" 
                       TextColor="#4A4A4A"
                       HorizontalOptions="Center"
                       Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>