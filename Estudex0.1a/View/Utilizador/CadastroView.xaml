<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.Utilizador.CadastroView"
             Title="Cadastro"
             BackgroundColor="#1a1a2e">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="Novo Cadastro"
                   FontSize="24" FontAttributes="Bold"
                   TextColor="#c084fc" Margin="0,20,0,10"/>

            <Entry Placeholder="Nome completo" Text="{Binding Nome}"
                   PlaceholderColor="#a0a0c0" TextColor="#e0e0ff"
                   BackgroundColor="#2d2b55" Margin="0,5"/>

            <Entry Placeholder="CPF (000.000.000-00)" Text="{Binding Cpf}"
                   PlaceholderColor="#a0a0c0" TextColor="#e0e0ff"
                   BackgroundColor="#2d2b55" Margin="0,5"
                   Keyboard="Numeric"/>

            <Entry Placeholder="Cidade" Text="{Binding Cidade}"
                   PlaceholderColor="#a0a0c0" TextColor="#e0e0ff"
                   BackgroundColor="#2d2b55" Margin="0,5"/>

            <Entry Placeholder="UF (ex: SP)" Text="{Binding Uf}"
                   PlaceholderColor="#a0a0c0" TextColor="#e0e0ff"
                   BackgroundColor="#2d2b55" Margin="0,5"
                   MaxLength="2"/>

            <Entry Placeholder="E-mail" Text="{Binding Email}"
                   PlaceholderColor="#a0a0c0" TextColor="#e0e0ff"
                   BackgroundColor="#2d2b55" Margin="0,5"
                   Keyboard="Email"/>

            <Entry Placeholder="Senha" Text="{Binding Senha}" IsPassword="True"
                   PlaceholderColor="#a0a0c0" TextColor="#e0e0ff"
                   BackgroundColor="#2d2b55" Margin="0,5"/>

            <Label Text="Tipo de usuário" TextColor="#a0a0c0" Margin="0,10,0,0"/>
            <Picker Title="Selecione o perfil"
                    SelectedItem="{Binding TipoSelecionado}"
                    TextColor="#e0e0ff"
                    BackgroundColor="#2d2b55">
                <Picker.Items>
                    <x:String>Aluno</x:String>
                    <x:String>Professor</x:String>
                </Picker.Items>
            </Picker>

            <Button Text="Registrar"
                    Command="{Binding RegistrarCommand}"
                    BackgroundColor="#7c3aed"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    Margin="0,20,0,0"
                    Clicked="OnRegistrarClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>