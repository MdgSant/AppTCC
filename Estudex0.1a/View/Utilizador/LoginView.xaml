<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.Utilizador.LoginView"
             Title="Login"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="InputFrame">
            <Setter Property="BackgroundColor" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasShadow" Value="False"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <!-- Fundo Escuro -->
        <Grid BackgroundColor="#121212"/>

        <!-- Círculos Decorativos -->
        <Ellipse Fill="#20BB86FC" WidthRequest="350" HeightRequest="350"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-200,-200,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-120,-120"/>
        <Ellipse Fill="#10BB86FC" WidthRequest="150" HeightRequest="150"
                 HorizontalOptions="Center" VerticalOptions="Center"
                 Margin="0,-100,0,0"/>

        <ScrollView>
            <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

                <!-- Logo/Título -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,40,0,20">
                    <Label Text="📚" FontSize="40" TextColor="#BB86FC"/>
                    <Label Text="ESTUDEX" 
                           FontSize="32" FontAttributes="Bold" 
                           TextColor="#a21fa2"/>
                </HorizontalStackLayout>

                <!-- Subtítulo -->
                <Label Text="Acesse sua conta e continue estudando" 
                       FontSize="14" 
                       TextColor="#9E9E9E"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"/>

                <!-- Card de Login -->
                <Frame BackgroundColor="#1E1E1E" 
                       CornerRadius="24" 
                       Padding="25"
                       HasShadow="True"
                       Margin="0,10,0,10">

                    <VerticalStackLayout Spacing="20">

                        <!-- Campo E-mail -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="E-MAIL" 
                                   FontSize="11" FontAttributes="Bold" 
                                   TextColor="#BB86FC"/>
                            <Frame Style="{StaticResource InputFrame}" HeightRequest="50">
                                <Entry Text="{Binding Email}"
                                       Placeholder="seu@email.com"
                                       PlaceholderColor="#6B6B6B"
                                       TextColor="#E0E0E0"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Keyboard="Email"
                                       Margin="15,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Campo Senha -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="SENHA" 
                                   FontSize="11" FontAttributes="Bold" 
                                   TextColor="#BB86FC"/>
                            <Frame Style="{StaticResource InputFrame}" HeightRequest="50">
                                <Entry Text="{Binding Senha}"
                                       Placeholder="********"
                                       PlaceholderColor="#6B6B6B"
                                       TextColor="#E0E0E0"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       IsPassword="True"
                                       Margin="15,0"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Opções: Lembrar-me + Esqueceu a senha -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,5,0,5">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                <CheckBox Color="#BB86FC" VerticalOptions="Center"/>
                                <Label Text="Lembrar-me" FontSize="12" TextColor="#9E9E9E" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Grid.Column="1" 
                                   Text="Esqueceu a senha?" 
                                   FontSize="12" 
                                   TextColor="#BB86FC"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Botão Entrar -->
                        <Button Text="ENTRAR →"
                                Background="{StaticResource PrimaryGradient}"
                                TextColor="#121212"
                                CornerRadius="25"
                                FontSize="15"
                                FontAttributes="Bold"
                                HeightRequest="50"
                                Margin="0,10,0,0"
                                Command="{Binding AutenticarCommand}"/>

                        <!-- Linha Divisória -->
                        <BoxView HeightRequest="1" BackgroundColor="#2A2A2A" Margin="0,15,0,15"/>

                        <!-- Cadastre-se -->
                        <HorizontalStackLayout  
                            HorizontalOptions="Center" 
                            Spacing="8">
                            <Label Text="Não possui login?" FontSize="13" TextColor="#9E9E9E"/>
                            <Label Text="Cadastre-se" 
                                   FontSize="13" 
                                   FontAttributes="Bold" 
                                   TextColor="#BB86FC">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding DirecionarCadastroCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <!-- Versão -->
                <Label Text="v1.0" 
                       FontSize="10" 
                       TextColor="#4A4A4A"
                       HorizontalOptions="Center"
                       Margin="0,20,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>