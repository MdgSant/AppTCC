<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.InserirPerguntaView"
             Title="Nova Questão"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="InputFrame">
            <Setter Property="BackgroundColor" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasShadow" Value="False"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Card Enunciado -->
                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="ENUNCIADO DA QUESTÃO" FontSize="14" FontAttributes="Bold" TextColor="#a21fa2"/>
                        <Frame Style="{StaticResource InputFrame}" Padding="12">
                            <Editor Text="{Binding Enunciado}" 
                                    FontSize="14" 
                                    TextColor="#E0E0E0" 
                                    Placeholder="Digite o enunciado..." 
                                    PlaceholderColor="#6B6B6B"
                                    HeightRequest="100"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Card Alternativas -->
                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="ALTERNATIVAS" FontSize="14" FontAttributes="Bold" TextColor="#a21fa2"/>

                        <StackLayout BindableLayout.ItemsSource="{Binding Opcoes}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">

                                        <!-- CheckBox sem verde, apenas borda roxa -->
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding Correta}" 
                                                  Color="#BB86FC"
                                                  VerticalOptions="Center"/>

                                        <!-- Letra da Alternativa -->
                                        <Frame Grid.Column="1" 
                                               WidthRequest="32" HeightRequest="32" 
                                               BackgroundColor="#BB86FC20" 
                                               CornerRadius="8">
                                            <Label Text="{Binding Letra}" 
                                                   FontSize="13" 
                                                   FontAttributes="Bold" 
                                                   TextColor="#BB86FC" 
                                                   HorizontalOptions="Center" 
                                                   VerticalOptions="Center"/>
                                        </Frame>

                                        <!-- Texto da Alternativa - BRANCO -->
                                        <Frame Grid.Column="2" 
                                               Style="{StaticResource InputFrame}" 
                                               HeightRequest="44">
                                            <Entry Text="{Binding Descricao}" 
                                                   Placeholder="Digite a alternativa..." 
                                                   PlaceholderColor="#6B6B6B"
                                                   TextColor="#E0E0E0"
                                                   FontSize="13"
                                                   Margin="12,0"/>
                                        </Frame>

                                        <!-- Botão Remover -->
                                        <Button Grid.Column="3" 
                                                Text="✕" 
                                                BackgroundColor="#F8717110" 
                                                TextColor="#F87171" 
                                                CornerRadius="8" 
                                                WidthRequest="36"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, 
                                                                  Path=BindingContext.RemoverOpcaoCommand}" 
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>

                        <!-- Botão Adicionar -->
                        <Button Text="+ ADICIONAR ALTERNATIVA" 
                                BackgroundColor="#2A2A2A" 
                                TextColor="#BB86FC" 
                                CornerRadius="10" 
                                FontSize="12"
                                FontAttributes="Bold"
                                HeightRequest="44"
                                Command="{Binding AdicionarOpcaoCommand}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Botões de Ação -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" 
                            Text="CANCELAR" 
                            BackgroundColor="#2A2A2A" 
                            TextColor="#F87171" 
                            CornerRadius="12" 
                            FontSize="12"
                            FontAttributes="Bold"
                            HeightRequest="48" 
                            Clicked="OnCancelarClicked"/>

                    <Button Grid.Column="1" 
                            Text="FINALIZAR" 
                            BackgroundColor="#2A2A2A" 
                            TextColor="#BB86FC" 
                            CornerRadius="12" 
                            FontSize="12"
                            FontAttributes="Bold"
                            HeightRequest="48" 
                            Command="{Binding FinalizarAtividadeCommand}"/>

                    <Button Grid.Column="2" 
                            Text="PRÓXIMA ▶" 
                            Background="{StaticResource PrimaryGradient}" 
                            TextColor="#121212" 
                            CornerRadius="12" 
                            FontSize="12"
                            FontAttributes="Bold"
                            HeightRequest="48" 
                            Command="{Binding ProximaQuestaoCommand}"/>
                </Grid>

                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>