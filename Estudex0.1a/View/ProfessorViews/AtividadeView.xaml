<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.AtividadeView"
             Title="AtividadeView">
    <ScrollView>
        <VerticalStackLayout Padding="10, 0, 0, 0" VerticalOptions="FillAndExpand">
            <ListView x:Name="listView" HasUnevenRows="True" ItemsSource="{Binding Atividades}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <StackLayout Padding="10">
                                <Label Text="{Binding Titulo}" 
                                   FontSize="18" 
                                   FontAttributes="Bold"/>
                                <Label Text="{Binding DataCriacao, StringFormat='Criado em: {0:dd/MM/yyyy}'}" 
                                   FontSize="14"/>
                                <Label Text="{Binding PontuacaoMaxima, StringFormat='Pontuação máxima: {0} pts'}" 
                                   FontSize="14"/>
                            </StackLayout>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>