<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.AtividadeView"
             Title="Atividades"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="AtividadeCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="TotalCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <!-- Círculos Decorativos -->
        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Header -->
                <HorizontalStackLayout>
                    <Label Text="📋" FontSize="26" TextColor="#BB86FC"/>
                    <Label Text="MINHAS ATIVIDADES" 
                           FontSize="20" FontAttributes="Bold" 
                           TextColor="#a21fa2"/>
                </HorizontalStackLayout>

                <!-- Card Total de Atividades -->
                <Frame Style="{StaticResource TotalCard}">
                    <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                        <Grid WidthRequest="50" HeightRequest="50">
                            <Ellipse Fill="#BB86FC20"/>
                            <Label Text="📋" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="TOTAL DE ATIVIDADES" FontSize="11" TextColor="#9E9E9E" FontAttributes="Bold"/>
                            <Label Text="{Binding Atividades.Count}" FontSize="32" FontAttributes="Bold" TextColor="#BB86FC"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- TÍTULO DA LISTA -->
                <Label Text="📝 MINHAS ATIVIDADES" 
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#BB86FC" Margin="0,5,0,5"/>

                <!-- LISTA DE ATIVIDADES -->
                <CollectionView ItemsSource="{Binding Atividades}"
                                SelectionMode="Single"
                                SelectionChanged="OnAtividadeSelecionada">
                    <CollectionView.EmptyView>
                        <Frame Style="{StaticResource AtividadeCard}" Padding="40">
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="📭" FontSize="40" HorizontalOptions="Center"/>
                                <Label Text="Nenhuma atividade cadastrada." 
                                       FontSize="13" TextColor="#9E9E9E" HorizontalOptions="Center"/>
                                <Label Text="Clique em + NOVA ATIVIDADE para começar" 
                                       FontSize="11" TextColor="#BB86FC" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource AtividadeCard}">
                                <VerticalStackLayout Spacing="12">

                                    <!-- Linha 1: Título + Badge Dificuldade -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding Titulo}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#E0E0E0"/>

                                        <!-- Badge de Dificuldade -->
                                        <Frame Grid.Column="1" CornerRadius="10" Padding="10,4" HasShadow="False">
                                            <Frame.Triggers>
                                                <DataTrigger TargetType="Frame" Binding="{Binding NivelDificuldade.Nome}" Value="Fácil">
                                                    <Setter Property="BackgroundColor" Value="#00E67610"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" Binding="{Binding NivelDificuldade.Nome}" Value="Médio">
                                                    <Setter Property="BackgroundColor" Value="#F59E0B10"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" Binding="{Binding NivelDificuldade.Nome}" Value="Difícil">
                                                    <Setter Property="BackgroundColor" Value="#F8717110"/>
                                                </DataTrigger>
                                            </Frame.Triggers>

                                            <Label FontSize="10" FontAttributes="Bold">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding NivelDificuldade.Nome}" Value="Fácil">
                                                        <Setter Property="Text" Value="⭐ FÁCIL"/>
                                                        <Setter Property="TextColor" Value="#00E676"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding NivelDificuldade.Nome}" Value="Médio">
                                                        <Setter Property="Text" Value="⚡ MÉDIO"/>
                                                        <Setter Property="TextColor" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding NivelDificuldade.Nome}" Value="Difícil">
                                                        <Setter Property="Text" Value="🔥 DIFÍCIL"/>
                                                        <Setter Property="TextColor" Value="#F87171"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Frame>
                                    </Grid>

                                    <!-- Separador -->
                                    <BoxView HeightRequest="1" BackgroundColor="#2A2A2A"/>

                                    <!-- Footer: Pontuação + Data -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                            <Label Text="🏆" FontSize="11"/>
                                            <Label Text="{Binding PontuacaoMaxima, StringFormat='{0} pontos'}"
                                                   FontSize="12" TextColor="#B0B0B0"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                            <Label Text="📅" FontSize="10" TextColor="#6B6B6B"/>
                                            <Label Text="{Binding DataCriacao, StringFormat='{0:dd/MM/yyyy}'}"
                                                   FontSize="11" TextColor="#6B6B6B"/>
                                        </HorizontalStackLayout>
                                    </Grid>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Botão Nova Atividade -->
                <Button Text="+ NOVA ATIVIDADE"
                        Background="{StaticResource PrimaryGradient}"
                        TextColor="#121212"
                        CornerRadius="25"
                        FontSize="13"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Margin="0,10,0,20"
                        Clicked="OnNovaAtividadeClicked"/>

                <!-- Loading -->
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>