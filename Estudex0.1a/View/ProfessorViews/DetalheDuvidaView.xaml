<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.DetalheDuvidaProfessorView"
             Title="Detalhe da Dúvida"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding Duvida.Titulo}" FontSize="17" FontAttributes="Bold" TextColor="#E0E0E0"/>
                            <Frame Grid.Column="1" CornerRadius="10" Padding="10,4" HasShadow="False" BackgroundColor="#FFC10720">
                                <Label Text="PENDENTE" FontSize="10" FontAttributes="Bold" TextColor="#FFC107"/>
                            </Frame>
                        </Grid>
                        <Label Text="{Binding Duvida.Utilizador.Nome}" FontSize="13" TextColor="#9E9E9E"/>
                        <Label Text="{Binding Duvida.Disciplina.Nome}" FontSize="13" TextColor="#a21fa2"/>
                        <Label Text="{Binding Duvida.Descricao}" FontSize="14" TextColor="#C0C0C0"/>
                        <Label Text="{Binding Duvida.Momento, StringFormat='📅 {0:dd/MM/yyyy HH:mm}'}" FontSize="11" TextColor="#6B6B6B" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

                <Label Text="💬 RESPOSTAS" FontSize="13" FontAttributes="Bold" TextColor="#BB86FC"/>

                <CollectionView ItemsSource="{Binding Respostas}">
                    <CollectionView.EmptyView>
                        <Frame Style="{StaticResource CardStyle}" Padding="40">
                            <Label Text="Nenhuma resposta ainda." FontSize="13" TextColor="#9E9E9E" HorizontalOptions="Center"/>
                        </Frame>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Utilizador.Nome}" FontSize="13" FontAttributes="Bold" TextColor="#a21fa2"/>
                                    <Label Text="{Binding ConteudoResposta}" FontSize="14" TextColor="#C0C0C0"/>
                                    <Label Text="{Binding Momento, StringFormat='📅 {0:dd/MM/yyyy HH:mm}'}" FontSize="11" TextColor="#6B6B6B" HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Editor Text="{Binding NovaResposta}"
                                Placeholder="Digite sua resposta aqui..."
                                PlaceholderColor="#6B6B6B"
                                TextColor="#E0E0E0"
                                BackgroundColor="#2A2A2A"
                                FontSize="14"
                                HeightRequest="100"/>
                        <Button Text="✈ ENVIAR RESPOSTA"
                                Background="{StaticResource PrimaryGradient}"
                                TextColor="#121212"
                                CornerRadius="12"
                                FontSize="13"
                                FontAttributes="Bold"
                                HeightRequest="48"
                                Command="{Binding EnviarRespostaCommand}"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
