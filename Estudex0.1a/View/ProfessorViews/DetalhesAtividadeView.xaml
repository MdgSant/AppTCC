<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.DetalhesAtividadeView"
             Title="Detalhes da Atividade"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="CardStyle">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="PerguntaCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="OpcaoFrame">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="HasShadow" Value="False"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <Ellipse Fill="#20BB86FC" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="Start" VerticalOptions="Start"
                 Margin="-150,-150,0,0"/>
        <Ellipse Fill="#20a21fa2" WidthRequest="250" HeightRequest="250"
                 HorizontalOptions="End" VerticalOptions="End"
                 Margin="0,0,-100,-100"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <Frame Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📋" FontSize="24" TextColor="#BB86FC"/>
                            <Label Text="{Binding Atividade.Titulo}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#E0E0E0"/>
                        </HorizontalStackLayout>

                        <!-- CORRIGIDO: Usando WrapLayout manual com Grid -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5" Margin="0,0,15,5">
                                <Label Text="⭐" FontSize="12"/>
                                <Label Text="Nível:" FontSize="12" TextColor="#9E9E9E"/>
                                <Label Text="{Binding Atividade.NivelDificuldade.Nome}"
                                       FontSize="12" FontAttributes="Bold" TextColor="#a21fa2"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5" Margin="0,0,15,5">
                                <Label Text="🏆" FontSize="12"/>
                                <Label Text="Pontuação:" FontSize="12" TextColor="#9E9E9E"/>
                                <Label Text="{Binding Atividade.PontuacaoMaxima, StringFormat='{0} pts'}"
                                       FontSize="12" FontAttributes="Bold" TextColor="#BB86FC"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5">
                                <Label Text="📅" FontSize="12"/>
                                <Label Text="Criada em:" FontSize="12" TextColor="#9E9E9E"/>
                                <Label Text="{Binding Atividade.DataCriacao, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                       FontSize="12" TextColor="#B0B0B0"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Label Text="📝 PERGUNTAS DA ATIVIDADE" 
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#BB86FC" Margin="0,5,0,5"/>

                <CollectionView ItemsSource="{Binding Atividade.Perguntas}">
                    <CollectionView.EmptyView>
                        <Frame Style="{StaticResource CardStyle}" Padding="40">
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="❓" FontSize="40" HorizontalOptions="Center"/>
                                <Label Text="Nenhuma pergunta cadastrada." 
                                       FontSize="13" TextColor="#9E9E9E" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource PerguntaCard}">
                                <VerticalStackLayout Spacing="15">

                                    <HorizontalStackLayout Spacing="10">
                                        <Grid WidthRequest="28" HeightRequest="28">
                                            <Ellipse Fill="#BB86FC20"/>
                                            <Label Text="❓" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Grid>
                                        <Label Text="{Binding Enunciado}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#E0E0E0"
                                               LineBreakMode="WordWrap"/>
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" BackgroundColor="#2A2A2A"/>

                                    <VerticalStackLayout Spacing="8" Margin="20,0,0,0">
                                        <Label Text="OPÇÕES DE RESPOSTA" 
                                               FontSize="10" FontAttributes="Bold"
                                               TextColor="#9E9E9E" Margin="0,0,0,5"/>

                                        <StackLayout BindableLayout.ItemsSource="{Binding Opcoes}" Spacing="8">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate>
                                                    <Frame Style="{StaticResource OpcaoFrame}" BackgroundColor="#252525">
                                                        <Frame.Triggers>
                                                            <DataTrigger TargetType="Frame" Binding="{Binding Correta}" Value="True">
                                                                <Setter Property="BackgroundColor" Value="#00E67610"/>
                                                                <Setter Property="BorderColor" Value="#00E676"/>
                                                            </DataTrigger>
                                                        </Frame.Triggers>

                                                        <HorizontalStackLayout Spacing="12">
                                                            <Label FontSize="14" FontAttributes="Bold">
                                                                <Label.Triggers>
                                                                    <DataTrigger TargetType="Label" Binding="{Binding Correta}" Value="True">
                                                                        <Setter Property="Text" Value="✓"/>
                                                                        <Setter Property="TextColor" Value="#00E676"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger TargetType="Label" Binding="{Binding Correta}" Value="False">
                                                                        <Setter Property="Text" Value="○"/>
                                                                        <Setter Property="TextColor" Value="#6B6B6B"/>
                                                                    </DataTrigger>
                                                                </Label.Triggers>
                                                            </Label>
                                                            <Label Text="{Binding Descricao}" FontSize="13" TextColor="#C0C0C0" VerticalOptions="Center" LineBreakMode="WordWrap"/>
                                                        </HorizontalStackLayout>
                                                    </Frame>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </StackLayout>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="👥 VER RESPOSTAS DOS ALUNOS"
                        Background="{StaticResource PrimaryGradient}"
                        TextColor="#121212"
                        CornerRadius="12"
                        FontSize="13"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        Margin="0,10,0,20"
                        Clicked="OnVerRespostasClicked"/>

                <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Color="#BB86FC" HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>