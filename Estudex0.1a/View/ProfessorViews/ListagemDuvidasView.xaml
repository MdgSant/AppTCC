<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.DuvidaView"
             Title="Dúvidas dos Alunos"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="PrimaryGradient" EndPoint="1,0">
            <GradientStop Color="#BB86FC" Offset="0" />
            <GradientStop Color="#a21fa2" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Frame" x:Key="StatCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>

        <Style TargetType="Frame" x:Key="DuvidaCard">
            <Setter Property="BackgroundColor" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid BackgroundColor="#121212"/>

        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Título -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Label Text="📋" FontSize="26" TextColor="#BB86FC"/>
                    <Label Text="DÚVIDAS DOS ALUNOS" 
                           FontSize="20" FontAttributes="Bold" 
                           TextColor="#a21fa2"/>
                </HorizontalStackLayout>

                <!-- STATS CARDS -->
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">

                    <Frame Style="{StaticResource StatCard}" WidthRequest="100">
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="⏳" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="PENDENTES" FontSize="9" TextColor="#9E9E9E"/>
                            <Label Text="{Binding TotalPendentes}" FontSize="26" FontAttributes="Bold" TextColor="#FFC107" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Style="{StaticResource StatCard}" WidthRequest="100">
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="✓" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="RESPONDIDAS" FontSize="9" TextColor="#9E9E9E"/>
                            <Label Text="{Binding TotalRespondidas}" FontSize="26" FontAttributes="Bold" TextColor="#00E676" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Style="{StaticResource StatCard}" WidthRequest="100">
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="TOTAL" FontSize="9" TextColor="#9E9E9E"/>
                            <Label Text="{Binding Total}" FontSize="26" FontAttributes="Bold" TextColor="#BB86FC" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </HorizontalStackLayout>

                <!-- BARRA DE BUSCA -->
                <Frame BackgroundColor="#1E1E1E" CornerRadius="25" Padding="10" HasShadow="True">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🔍" FontSize="14" TextColor="#BB86FC" VerticalOptions="Center"/>
                        <Entry x:Name="EntryIdDuvida"
                               Placeholder="Buscar por ID da dúvida..."
                               PlaceholderColor="#6B6B6B"
                               TextColor="#E0E0E0"
                               BackgroundColor="Transparent"
                               HorizontalOptions="FillAndExpand"
                               FontSize="13"
                               Keyboard="Numeric"/>
                        <Button Text="BUSCAR"
                                BackgroundColor="#BB86FC"
                                TextColor="#121212"
                                CornerRadius="15"
                                FontSize="11"
                                FontAttributes="Bold"
                                WidthRequest="70"
                                HeightRequest="32"
                                Clicked="OnBuscarPorIdClicked"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- TÍTULO DA LISTA -->
                <Label Text="ÚLTIMAS DÚVIDAS" 
                       FontSize="13" FontAttributes="Bold"
                       TextColor="#BB86FC" Margin="0,5,0,5"/>

                <!-- LISTA VERTICAL COM CARDS CLICÁVEIS -->
                <CollectionView ItemsSource="{Binding Duvidas}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource DuvidaCard}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnDuvidaTapped"/>
                                </Frame.GestureRecognizers>

                                <VerticalStackLayout Spacing="12">

                                    <!-- Linha 1: Nome + Disciplina + Status -->
                                    <Grid ColumnDefinitions="Auto,*,Auto">

                                        <HorizontalStackLayout Grid.Column="0" Spacing="10">
                                            <Grid WidthRequest="36" HeightRequest="36">
                                                <Ellipse Fill="#BB86FC20"/>
                                                <Label Text="👨‍🎓" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Grid>
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding Utilizador.Nome}" FontSize="14" FontAttributes="Bold" TextColor="#E0E0E0"/>
                                                <Label Text="{Binding Disciplina.Nome}" FontSize="10" TextColor="#a21fa2"/>
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>

                                        <!-- Status Badge - Usando apenas DataTrigger -->
                                        <Frame Grid.Column="2" CornerRadius="10" Padding="8,3" HasShadow="False"
                                               HorizontalOptions="End" VerticalOptions="Center"
                                               BackgroundColor="#FFC10720">
                                            <Frame.Triggers>
                                                <DataTrigger TargetType="Frame" Binding="{Binding StatusDuvida}" Value="respondida">
                                                    <Setter Property="BackgroundColor" Value="#00E67620"/>
                                                </DataTrigger>
                                            </Frame.Triggers>

                                            <Label FontSize="9" FontAttributes="Bold" Text="⏳ PENDENTE" TextColor="#FFC107">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding StatusDuvida}" Value="respondida">
                                                        <Setter Property="Text" Value="✓ RESPONDIDA"/>
                                                        <Setter Property="TextColor" Value="#00E676"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Frame>
                                    </Grid>

                                    <!-- Título -->
                                    <Label Text="{Binding Titulo}" 
                                           FontSize="15" FontAttributes="Bold" 
                                           TextColor="#BB86FC"
                                           Margin="46,0,0,0"/>

                                    <!-- Descrição -->
                                    <Frame BackgroundColor="#252525" CornerRadius="10" Padding="12" HasShadow="False" Margin="46,0,0,0">
                                        <Label Text="{Binding Descricao}" 
                                               FontSize="12" TextColor="#B0B0B0"
                                               LineBreakMode="WordWrap"/>
                                    </Frame>

                                    <!-- Footer: Data -->
                                    <HorizontalStackLayout Spacing="12" Margin="46,0,0,0">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📅" FontSize="10" TextColor="#6B6B6B"/>
                                            <Label Text="{Binding Momento, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="10" TextColor="#6B6B6B"/>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- LOADING -->
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="#BB86FC"
                                   HeightRequest="40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
