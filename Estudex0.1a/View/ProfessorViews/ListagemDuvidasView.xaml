<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Estudex0._1a.View.ProfessorViews.DuvidaView"
             Title="Dúvidas"
             BackgroundColor="#1a1a2e">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20" RowSpacing="16">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="? Dúvidas dos Alunos"
                   FontSize="24" FontAttributes="Bold" TextColor="#c084fc" />
            <BoxView HeightRequest="1" BackgroundColor="#3d3b6e" Margin="0,8,0,0" />
        </VerticalStackLayout>

        <!-- Cards de métricas -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="10">

            <Frame Grid.Column="0" BackgroundColor="#2d2b55" CornerRadius="12"
                   Padding="12" BorderColor="#3d3b6e">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="🕐" FontSize="20" HorizontalOptions="Center" />
                    <Label Text="Pendentes" FontSize="11" TextColor="#a0a0c0" HorizontalOptions="Center" />
                    <Label Text="{Binding TotalPendentes}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="#f59e0b" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <Frame Grid.Column="1" BackgroundColor="#2d2b55" CornerRadius="12"
                   Padding="12" BorderColor="#3d3b6e">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="✅" FontSize="20" HorizontalOptions="Center" />
                    <Label Text="Respondidas" FontSize="11" TextColor="#a0a0c0" HorizontalOptions="Center" />
                    <Label Text="{Binding TotalRespondidas}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="#4ade80" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <Frame Grid.Column="2" BackgroundColor="#2d2b55" CornerRadius="12"
                   Padding="12" BorderColor="#3d3b6e">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="📋" FontSize="20" HorizontalOptions="Center" />
                    <Label Text="Total" FontSize="11" TextColor="#a0a0c0" HorizontalOptions="Center" />
                    <Label Text="{Binding Total}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="#c084fc" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

        </Grid>

        <!-- Lista -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Duvidas}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#2d2b55" CornerRadius="14"
                           Padding="16" BorderColor="#3d3b6e" Margin="0,0,0,12">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">

                            <!-- Nome + Badge Status -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Utilizador.Nome}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#e0e0ff" />

                                <Frame Grid.Column="1" CornerRadius="8"
                                       Padding="8,4" BorderColor="Transparent"
                                       BackgroundColor="#1a3a1a">
                                    <Frame.Triggers>
                                        <DataTrigger TargetType="Frame"
                                                     Binding="{Binding StatusDuvida}"
                                                     Value="Aberta">
                                            <Setter Property="BackgroundColor" Value="#3a2a0a" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Frame"
                                                     Binding="{Binding StatusDuvida}"
                                                     Value="Respondida">
                                            <Setter Property="BackgroundColor" Value="#1a3a1a" />
                                        </DataTrigger>
                                    </Frame.Triggers>

                                    <Label Text="{Binding StatusDuvida}" FontSize="12">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding StatusDuvida}"
                                                         Value="Aberta">
                                                <Setter Property="TextColor" Value="#f59e0b" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding StatusDuvida}"
                                                         Value="Respondida">
                                                <Setter Property="TextColor" Value="#4ade80" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Frame>
                            </Grid>

                            <!-- Disciplina -->
                            <Label Grid.Row="1"
                                   Text="{Binding Disciplina.Nome}"
                                   FontSize="12" TextColor="#a0a0c0" />

                            <!-- Título da dúvida -->
                            <Label Grid.Row="2"
                                   Text="{Binding Titulo}"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#c084fc" />

                            <!-- Descrição + Data -->
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Descricao}"
                                       FontSize="13" TextColor="#a0a0c0"
                                       LineBreakMode="TailTruncation" MaxLines="2" />
                                <Label Grid.Column="1"
                                       Text="{Binding Momento, StringFormat='📅 {0:dd/MM/yyyy}'}"
                                       FontSize="12" TextColor="#a0a0c0"
                                       VerticalOptions="End" />
                            </Grid>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Botão -->
        <Button Grid.Row="3"
                Text="+ Nova Dúvida"
                BackgroundColor="#7c3aed"
                TextColor="White"
                CornerRadius="12"
                FontSize="15"
                FontAttributes="Bold"
                HeightRequest="52"
                Clicked="OnNovaDuvidaClicked" />

    </Grid>
</ContentPage>